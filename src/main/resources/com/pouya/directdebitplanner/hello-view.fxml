<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.pouya.directdebitplanner.HelloController">

    <top>
        <Label text="Direct Debit Planner" style="-fx-font-size: 24px; -fx-padding: 15;" />
    </top>

    <center>
        <VBox spacing="15" style="-fx-padding: 20;">

            <TextField fx:id="nameField" promptText="Direct Debit Name" />
            <TextField fx:id="amountField" promptText="Amount" />
            <TextField fx:id="dateField" promptText="Due Date (e.g. 15th)" />
            <TextField fx:id="categoryField" promptText="Category" />
            <TextArea fx:id="notesField" promptText="Notes" prefHeight="80" />

            <HBox spacing="10">
                <Button text="Add Direct Debit" onAction="#addDebit" />
                <Button text="Delete Selected" onAction="#deleteSelectedDebit" />
            </HBox>

            <TextField fx:id="searchField" promptText="Search by name, category, notes, or due date..." />

            <TableView fx:id="debitTable" prefHeight="250">
                <columns>
                    <TableColumn fx:id="nameColumn" text="Name" prefWidth="150" />
                    <TableColumn fx:id="amountColumn" text="Amount" prefWidth="100" />
                    <TableColumn fx:id="dateColumn" text="Due Date" prefWidth="100" />
                    <TableColumn fx:id="categoryColumn" text="Category" prefWidth="120" />
                    <TableColumn fx:id="notesColumn" text="Notes" prefWidth="200" />
                </columns>
            </TableView>

            <Label fx:id="totalLabel" text="Monthly Total: £0.00"
                   style="-fx-font-size: 16px; -fx-font-weight: bold;" />

        </VBox>
    </center>

</BorderPane>